# Frontend
VITE_APP_NAME=ACOO
VITE_CODEX_MODEL_DEFAULT=gpt-5.4
VITE_CODEX_REASONING_EFFORT_DEFAULT=high
VITE_CODEX_SANDBOX_MODE_DEFAULT=danger-full-access
VITE_CODEX_APPROVAL_POLICY_DEFAULT=never
VITE_TELEGRAM_ENABLED=false
VITE_TELEGRAM_BOT_USERNAME=
VITE_TELEGRAM_ALLOWED_USERS_COUNT=0
VITE_TELEGRAM_AUDIO_REPLY_DEFAULT=false

# Codex CLI integration
DATABASE_URL="file:../data/acoo.db"
ACOO_API_HOST=127.0.0.1
ACOO_API_PORT=4317
ACOO_CODEX_CLI_BIN=codex
ACOO_CODEX_CONFIG_PATH=~/.codex/config.toml
ACOO_CODEX_MODEL=gpt-5.4
ACOO_CODEX_REASONING_EFFORT=high
ACOO_CODEX_SANDBOX_MODE=danger-full-access
ACOO_CODEX_APPROVAL_POLICY=never
ACOO_PLAYWRIGHT_MCP_HEALTHCHECK_COMMAND=node scripts/playwright-mcp-healthcheck.mjs
ACOO_PLAYWRIGHT_MCP_HEALTHCHECK_URL=http://127.0.0.1:9222/json/version
ACOO_PLAYWRIGHT_MCP_STARTUP_COMMAND=~/.local/bin/playwright-mcp-brave-open
ACOO_PLAYWRIGHT_MCP_AUTOSTART=false

# Telegram channel
ACOO_TELEGRAM_ENABLED=false
ACOO_TELEGRAM_BOT_TOKEN=
ACOO_TELEGRAM_BOT_USERNAME=
ACOO_TELEGRAM_ALLOWED_USER_IDS=
ACOO_TELEGRAM_PROGRESS_PULSE_MS=4000
ACOO_TELEGRAM_REPLY_AUDIO_BY_DEFAULT=false

# Local transcription
ACOO_STT_ENABLED=true
ACOO_STT_BINARY=whisper-cli
ACOO_STT_FFMPEG_BIN=ffmpeg
ACOO_STT_MODEL=base
ACOO_STT_MODEL_PATH=
ACOO_STT_MODEL_URL=
ACOO_STT_LANGUAGE=
ACOO_STT_THREADS=4
ACOO_STT_MODEL_DOWNLOADER_BIN=curl

# Operational runtime
ACOO_SKILL_ROOTS=.agents/skills,~/.codex/skills
