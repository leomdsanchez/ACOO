# Frontend
VITE_APP_NAME=ACOO

# Codex CLI integration
ACOO_CODEX_CLI_BIN=codex
ACOO_CODEX_CONFIG_PATH=~/.codex/config.toml
ACOO_MCP_SERVER_NAME=acoo

# Agent runtime
ACOO_CONVERSATIONS_FILE=data/conversations.json
ACOO_DEFAULT_CONVERSATION_ID=local-main
ACOO_MAX_ITERATIONS=5
ACOO_SKILL_ROOTS=agents,~/.codex/skills
