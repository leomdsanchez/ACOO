{
  "name": "acoo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:ui": "vite",
    "dev:telegram": "tsx server/commands/telegram.ts --drop-pending",
    "build": "tsc -b && vite build",
    "prisma:generate": "prisma generate",
    "prisma:db:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:setup": "npm run prisma:db:push && npm run prisma:seed",
    "preview": "vite preview",
    "server:api": "tsx server/commands/api.ts",
    "server:agents": "tsx server/commands/agents.ts",
    "server:mcp": "tsx server/commands/mcp.ts",
    "server:registry": "tsx server/commands/registry.ts",
    "server:run": "tsx server/commands/run.ts",
    "server:status": "tsx server/commands/status.ts",
    "server:telegram": "tsx server/commands/telegram.ts",
    "test:server": "node --import tsx --test server/**/*.test.ts",
    "typecheck": "tsc -b",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "clockify:summary-debug": "node scripts/clockify-summary-debug.mjs",
    "clockify:summary-snippet": "node scripts/clockify-summary-snippet.mjs",
    "linkedin:activity-snippet": "node scripts/linkedin-activity-snippet.mjs",
    "linkedin:snapshot-parse": "node scripts/linkedin-snapshot-parse.mjs"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.118",
    "@playwright/mcp": "^0.0.68",
    "@prisma/client": "^6.16.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "media-chrome": "^4.18.1",
    "nanoid": "^5.1.7",
    "playwright-core": "^1.58.2",
    "prisma": "^6.16.2",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "shadcn": "^4.0.8",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "use-stick-to-bottom": "^1.1.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "playwright": "^1.54.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
